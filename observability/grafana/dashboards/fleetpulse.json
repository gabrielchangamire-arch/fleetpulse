{"title":"FleetPulse Reliability","uid":"fleetpulse-reliability","schemaVersion":39,"version":1,"panels":[{"type":"timeseries","title":"API request rate","targets":[{"expr":"sum(rate(fleetpulse_http_requests_total[5m]))"}],"gridPos":{"h":8,"w":12,"x":0,"y":0}},{"type":"timeseries","title":"p95 latency","targets":[{"expr":"histogram_quantile(0.95, sum by (le) (rate(fleetpulse_http_request_duration_seconds_bucket[5m])))"}],"gridPos":{"h":8,"w":12,"x":12,"y":0}},{"type":"stat","title":"Cache hit rate","targets":[{"expr":"sum(fleetpulse_cache_requests_total{status=\"hit\"}) / clamp_min(sum(fleetpulse_cache_requests_total),1)"}],"gridPos":{"h":8,"w":8,"x":0,"y":8}},{"type":"stat","title":"Worker events","targets":[{"expr":"sum(fleetpulse_worker_events_total)"}],"gridPos":{"h":8,"w":8,"x":8,"y":8}}]}
