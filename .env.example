# Copy this file to the ignored `.env` and replace both placeholders.
# Values here are documentation placeholders, not usable credentials.
FLEETPULSE_ENV=development
FLEETPULSE_LOG_LEVEL=INFO
FLEETPULSE_AGENT_TOKEN=replace-with-a-random-local-token
FLEETPULSE_POSTGRES_PASSWORD=replace-with-a-random-local-password

# The assistant is disabled unless the `ai` Compose profile is selected.
# Offline mode is deterministic and requires no external service or credential.
FLEETPULSE_ASSISTANT_PROVIDER=offline
FLEETPULSE_ASSISTANT_MODEL=gpt-5-mini
# Set FLEETPULSE_ASSISTANT_API_KEY only in your ignored local .env when explicitly using OpenAI.
